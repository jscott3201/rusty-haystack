class HDict:
    """Haystack Dict — a collection of name/value tag pairs.

    The fundamental data type for representing entities and records.

    Examples:
        d = HDict({"dis": "Main Site", "area": Number(5000, "ft²")})
        d.get("dis")  # "Main Site"
        d.has("area")  # True
    """
    def __init__(self, tags: dict[str, Any] | None = None) -> None: ...
    def has(self, name: str) -> bool:
        """Return True if the tag is present."""
        ...
    def get(self, name: str, default: Any = None) -> Any:
        """Get a tag value by name, returning default (None) if missing."""
        ...
    def missing(self, name: str) -> bool:
        """Return True if the tag is absent."""
        ...
    def id(self) -> Ref | None:
        """Return the 'id' Ref tag value, or None."""
        ...
    def dis(self) -> str | None:
        """Return the display string ('dis' tag), or None."""
        ...
    def is_empty(self) -> bool:
        """Return True if the dict has no tags."""
        ...
    def set(self, name: str, val: Any) -> None:
        """Set a tag value. Overwrites existing."""
        ...
    def merge(self, other: HDict) -> None:
        """Merge tags from another HDict. Existing tags are overwritten."""
        ...
    @staticmethod
    def from_dict(d: dict[str, Any]) -> HDict:
        """Create an HDict from a Python dict."""
        ...
    def to_dict(self) -> dict[str, Any]:
        """Convert to a Python dict with string keys."""
        ...
    def sorted_keys(self) -> list[str]:
        """Return tag names in sorted order."""
        ...
    def copy(self) -> HDict:
        """Return a shallow copy of this dict."""
        ...
    @property
    def ref_val(self) -> str | None:
        """The ref value string of the 'id' tag, or None."""
        ...
    def tag_names(self) -> list[str]:
        """Return all tag names as a list."""
        ...
    def keys(self) -> list[str]:
        """Return tag names (alias for tag_names)."""
        ...
    def values(self) -> list[Any]:
        """Return all tag values."""
        ...
    def items(self) -> list[tuple[str, Any]]:
        """Return (name, value) pairs."""
        ...
    def __len__(self) -> int: ...
    def __contains__(self, name: str) -> bool: ...
    def __getitem__(self, name: str) -> Any: ...
    def __setitem__(self, name: str, val: Any) -> None: ...
    def __delitem__(self, name: str) -> None: ...
    def __iter__(self) -> Iterator[str]: ...
    def __repr__(self) -> str: ...
    def __str__(self) -> str: ...
    def __eq__(self, other: object) -> bool: ...
    def __ne__(self, other: object) -> bool: ...

