  *xstr: Obj

  // Original year of construction as four digit year such as 1980
  *yearBuilt: Int

  // Low power wireless communication protocol for home automation
  *zigbee: Marker

  // Related to spaces from a system perspective
  *zone: Marker

  // Low power wireless communication protocol for home automation
  *zwave: Marker
}


