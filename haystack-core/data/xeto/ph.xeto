  *visibility: Marker

  // Electrical potential difference or electromotive force.
  *volt: Marker

  // Three dimensional space occupied by a substance
  *volume: Marker

  // Variable refigerant flow.  See [ph.doc::VRF] chapter.
  *vrf: Marker

