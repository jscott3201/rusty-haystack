  mlIdentificationPeriod: Span?
  mlInputVarRefs:         List?
  mlModelMetrics:         Dict?
  mlModelParameters:      Dict?
  mlOutputVarRef:         Ref?
}

// Machine learning variable representing both model inputs and outputs.
MlVar: PhEntity {
  mlVar
  mlVarFilter: Str?
  mlVarPoint:  Ref?
}

// See [ph.doc::Synthetics] chapter.
SimPoint: SyntheticPoint <abstract> {
